rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function ownsParentBatch(batchId) {
      let batch = get(/databases/$(database)/documents/batches/$(batchId));
      return batch != null && batch.data.ownerId == request.auth.uid;
    }

    // ── Users ────────────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // ── Batches ──────────────────────────────────────────────────
    match /batches/{batchId} {
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid && request.resource.data.currentWeek == 1;

      allow read, delete: if isAuthenticated() && resource.data.ownerId == request.auth.uid;

      allow update: if isAuthenticated() && resource.data.ownerId == request.auth.uid && request.resource.data.ownerId == request.auth.uid && request.resource.data.currentWeek >= 1 && request.resource.data.currentWeek <= resource.data.currentWeek + 1;
    }

    // ── Students ─────────────────────────────────────────────────
    match /students/{studentId} {
      allow read, delete: if isAuthenticated() && ownsParentBatch(resource.data.batchId);

      allow create: if isAuthenticated() && ownsParentBatch(request.resource.data.batchId);

      allow update: if isAuthenticated() && ownsParentBatch(resource.data.batchId) && ownsParentBatch(request.resource.data.batchId);
    }

    // ── Sessions ─────────────────────────────────────────────────
    match /sessions/{sessionId} {
      allow read, delete: if isAuthenticated() && ownsParentBatch(resource.data.batchId);

      allow create: if isAuthenticated() && ownsParentBatch(request.resource.data.batchId);

      allow update: if isAuthenticated() && ownsParentBatch(resource.data.batchId) && ownsParentBatch(request.resource.data.batchId);
    }

    // ── Weekly Entries ───────────────────────────────────────────
    match /weeklyEntries/{entryId} {
      function validRating() {
        return request.resource.data.rating in
          ['Need Support', 'Average', 'Good', 'Outstanding'];
      }

      function validEntry() {
        return request.resource.data.keys().hasAll([
          'studentId', 'batchId', 'week', 'rating'
        ])
        && validRating()
        && request.resource.data.week is int;
      }

      allow read, delete: if isAuthenticated() && ownsParentBatch(resource.data.batchId);

      allow create: if isAuthenticated() && ownsParentBatch(request.resource.data.batchId) && validEntry();

      allow update: if isAuthenticated() && ownsParentBatch(resource.data.batchId) && ownsParentBatch(request.resource.data.batchId) && validEntry();
    }
  }
}